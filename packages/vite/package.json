{
	"name": "@almeidx/version-check-vite",
	"version": "1.0.0",
	"description": "Vite plugin for @almeidx/version-check.",
	"keywords": [
		"build-id",
		"deployment",
		"esm",
		"frontend",
		"typescript",
		"update-detector",
		"version-check",
		"vite",
		"vite-plugin"
	],
	"homepage": "https://github.com/almeidx/version-check/tree/main/packages/vite#readme",
	"bugs": {
		"url": "https://github.com/almeidx/version-check/issues"
	},
	"license": "Apache-2.0",
	"author": "almeidx (https://almeidx.dev)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/almeidx/version-check.git",
		"directory": "packages/vite"
	},
	"bin": {
		"version-check": "./bin/version-check.mjs"
	},
	"files": [
		"CHANGELOG.md",
		"README.md",
		"bin",
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		},
		"./virtual": {
			"types": "./dist/virtual.d.ts",
			"default": "./dist/virtual.mjs"
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"typecheck": "tsc --noEmit -p tsconfig.json"
	},
	"dependencies": {
		"@almeidx/version-check": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^24.13.3",
		"tsdown": "^0.22.4",
		"typescript": "^7.0.2",
		"vite": "^8.1.4",
		"vitest": "^4.1.10"
	},
	"peerDependencies": {
		"vite": ">=6"
	}
}
