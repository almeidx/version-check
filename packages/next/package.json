{
	"name": "@almeidx/version-check-next",
	"version": "0.1.0",
	"description": "Next.js adapter for @almeidx/version-check.",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/almeidx/version-check.git",
		"directory": "packages/next"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		},
		"./client": {
			"import": {
				"types": "./dist/client.d.mts",
				"default": "./dist/client.mjs"
			}
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"typecheck": "tsc --noEmit -p tsconfig.json"
	},
	"dependencies": {
		"@almeidx/version-check": "workspace:*",
		"@almeidx/version-check-react": "workspace:*"
	},
	"devDependencies": {
		"@types/react": "^19.2.15",
		"next": "^16.2.6",
		"react": "^19.2.6",
		"tsdown": "^0.22.1",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"next": ">=14.0.0",
		"react": ">=18.3.0 || >=19.0.0"
	}
}
