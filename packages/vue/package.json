{
	"name": "@almeidx/version-check-vue",
	"version": "1.0.0",
	"description": "Vue adapter for @almeidx/version-check.",
	"keywords": [
		"build-id",
		"deployment",
		"esm",
		"frontend",
		"typescript",
		"update-detector",
		"version-check",
		"vue",
		"vue-composable"
	],
	"homepage": "https://github.com/almeidx/version-check/tree/main/packages/vue#readme",
	"bugs": {
		"url": "https://github.com/almeidx/version-check/issues"
	},
	"license": "Apache-2.0",
	"author": "almeidx (https://almeidx.dev)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/almeidx/version-check.git",
		"directory": "packages/vue"
	},
	"bin": {
		"version-check": "./bin/version-check.mjs"
	},
	"files": [
		"CHANGELOG.md",
		"README.md",
		"bin",
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"typecheck": "tsc --noEmit -p tsconfig.json"
	},
	"dependencies": {
		"@almeidx/version-check": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^24.13.3",
		"tsdown": "^0.22.9",
		"typescript": "^7.0.2",
		"vue": "^3.5.40"
	},
	"peerDependencies": {
		"vue": ">=3.4.0"
	}
}
