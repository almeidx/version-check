{
	"name": "@almeidx/version-check-vue",
	"version": "0.1.0",
	"description": "Vue adapter for @almeidx/version-check.",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/almeidx/version-check.git",
		"directory": "packages/vue"
	},
	"bin": {
		"version-check": "./bin/version-check.mjs"
	},
	"files": [
		"bin",
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"typecheck": "tsc --noEmit -p tsconfig.json"
	},
	"dependencies": {
		"@almeidx/version-check": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^24.12.4",
		"tsdown": "^0.22.1",
		"typescript": "^6.0.3",
		"vue": "^3.5.35"
	},
	"peerDependencies": {
		"vue": ">=3.4.0"
	}
}
