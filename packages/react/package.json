{
	"name": "@almeidx/version-check-react",
	"version": "0.1.0",
	"description": "React adapter for @almeidx/version-check.",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/almeidx/version-check.git",
		"directory": "packages/react"
	},
	"bin": {
		"version-check": "./dist/cli.mjs"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"typecheck": "tsc --noEmit -p tsconfig.json"
	},
	"dependencies": {
		"@almeidx/version-check": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^24.12.4",
		"@types/react": "^19.2.15",
		"react": "^19.2.6",
		"tsdown": "^0.22.1",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"react": ">=18.3.0 || >=19.0.0"
	}
}
