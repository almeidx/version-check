{
	"name": "@almeidx/version-check-react",
	"version": "1.0.0",
	"description": "React adapter for @almeidx/version-check.",
	"keywords": [
		"build-id",
		"deployment",
		"esm",
		"frontend",
		"react",
		"react-hook",
		"typescript",
		"update-detector",
		"version-check"
	],
	"homepage": "https://github.com/almeidx/version-check/tree/main/packages/react#readme",
	"bugs": {
		"url": "https://github.com/almeidx/version-check/issues"
	},
	"license": "Apache-2.0",
	"author": "almeidx (https://almeidx.dev)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/almeidx/version-check.git",
		"directory": "packages/react"
	},
	"bin": {
		"version-check": "./bin/version-check.mjs"
	},
	"files": [
		"CHANGELOG.md",
		"README.md",
		"bin",
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"typecheck": "tsc --noEmit -p tsconfig.json"
	},
	"dependencies": {
		"@almeidx/version-check": "workspace:*"
	},
	"devDependencies": {
		"@testing-library/react": "^16.3.2",
		"@types/node": "^24.13.3",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"react": "^19.2.7",
		"react-dom": "19.2.7",
		"tsdown": "^0.22.4",
		"typescript": "^7.0.2"
	},
	"peerDependencies": {
		"react": ">=18.3.0"
	}
}
