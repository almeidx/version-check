{
	"name": "@almeidx/version-check",
	"version": "0.2.0-next.4",
	"description": "Headless web app version/update detector.",
	"keywords": [
		"build-id",
		"deployment",
		"esm",
		"frontend",
		"polling",
		"typescript",
		"update-detector",
		"version-check"
	],
	"homepage": "https://github.com/almeidx/version-check/tree/main/packages/core#readme",
	"bugs": {
		"url": "https://github.com/almeidx/version-check/issues"
	},
	"license": "Apache-2.0",
	"author": "almeidx (https://almeidx.dev)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/almeidx/version-check.git",
		"directory": "packages/core"
	},
	"bin": {
		"version-check": "./bin/version-check.mjs"
	},
	"files": [
		"CHANGELOG.md",
		"README.md",
		"bin",
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		},
		"./cli": {
			"import": {
				"types": "./dist/cli.d.mts",
				"default": "./dist/cli.mjs"
			}
		},
		"./build": {
			"import": {
				"types": "./dist/build-id.d.mts",
				"default": "./dist/build-id.mjs"
			}
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"typecheck": "tsc --noEmit -p tsconfig.json"
	},
	"devDependencies": {
		"@types/node": "^24.13.2",
		"tsdown": "^0.22.2",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	}
}
