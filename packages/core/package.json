{
	"name": "@almeidx/version-check",
	"version": "0.2.0-next.0",
	"description": "Headless web app version/update detector.",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/almeidx/version-check.git",
		"directory": "packages/core"
	},
	"bin": {
		"version-check": "./bin/version-check.mjs"
	},
	"files": [
		"bin",
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		},
		"./cli": {
			"import": {
				"types": "./dist/cli.d.mts",
				"default": "./dist/cli.mjs"
			}
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"typecheck": "tsc --noEmit -p tsconfig.json"
	},
	"devDependencies": {
		"@types/node": "^24.12.4",
		"tsdown": "^0.22.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.7"
	}
}
