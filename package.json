{
	"name": "version-check",
	"version": "0.2.0-next.4",
	"private": true,
	"description": "Headless web app version/update detector.",
	"keywords": [
		"app",
		"build-id",
		"deploy",
		"frontend",
		"version-check"
	],
	"homepage": "https://github.com/almeidx/version-check#readme",
	"bugs": "https://github.com/almeidx/version-check/issues",
	"license": "Apache-2.0",
	"author": "almeidx (https://almeidx.dev)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/almeidx/version-check.git"
	},
	"type": "module",
	"scripts": {
		"build": "pnpm -r --filter './packages/*' build && pnpm -r --filter './examples/*' build",
		"dev": "pnpm --parallel --filter './packages/*' dev",
		"test": "vitest run",
		"build:typecheck": "pnpm -r typecheck",
		"lint": "oxfmt --check && oxlint --import-plugin --react-plugin --vitest-plugin --jsx-a11y-plugin --vue-plugin",
		"publint": "pnpm -r --filter './packages/*' exec publint",
		"fmt": "oxfmt --write && oxlint --fix --import-plugin --react-plugin --vitest-plugin --jsx-a11y-plugin --vue-plugin",
		"fmt:check": "oxfmt --check",
		"check": "pnpm lint && pnpm build:typecheck && pnpm test && pnpm build && pnpm publint",
		"generate:version": "pnpm --filter @almeidx/version-check build && node packages/core/dist/cli.mjs generate",
		"prepare": "husky .github/husky"
	},
	"devDependencies": {
		"@types/node": "^24.12.4",
		"happy-dom": "^20.10.2",
		"husky": "^9.1.7",
		"oxfmt": "^0.52.0",
		"oxlint": "^1.67.0",
		"publint": "^0.3.21",
		"tsdown": "^0.22.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.7"
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"packageManager": "pnpm@11.5.0"
}
